{
  "name": "ai-tab-organizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit",
    "test": "vitest run --exclude tests/build-output.test.ts",
    "test:watch": "vitest",
    "test:build": "npm run build && vitest run tests/build-output.test.ts",
    "verify": "npm run check && npm run test && npm run test:build"
  },
  "dependencies": {
    "tldts": "^7.0.14"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.3",
    "@types/node": "^24.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
